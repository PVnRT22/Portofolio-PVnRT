<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pandu Dian | Integrated Lab Portfolio</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <style>
        :root {
            --bg-primary: #0a0f1d;
            --bg-secondary: #111827;
            --bg-card: #1f2937;
            --accent-cyan: #06b6d4;
            --accent-blue: #3b82f6;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border-lab: #22d3ee33;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-main);
            overflow-x: hidden;
        }

        /* Lab Grid Background Effect */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(var(--border-lab) 1px, transparent 1px),
                              linear-gradient(90deg, var(--border-lab) 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: -1;
            opacity: 0.15;
            pointer-events: none;
        }

        /* Navbar */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 15, 29, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-lab);
            z-index: 1000;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo {
            font-family: 'Courier New', Courier, monospace;
            font-weight: bold;
            color: var(--accent-cyan);
            font-size: 1.2rem;
            letter-spacing: 2px;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--text-main);
            text-decoration: none;
            font-size: 0.95rem;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-links a:hover {
            color: var(--accent-cyan);
            text-shadow: 0 0 8px var(--accent-cyan);
        }

        /* Hero Section */
        header {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 7rem 2rem 4rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            gap: 4rem;
        }

        .hero-text {
            flex: 1;
        }

        .hero-tag {
            font-family: 'Courier New', Courier, monospace;
            color: var(--accent-cyan);
            background: rgba(6, 182, 212, 0.1);
            padding: 0.4rem 0.8rem;
            border-left: 3px solid var(--accent-cyan);
            display: inline-block;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        .hero-text h1 {
            font-size: 3.5rem;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            background: linear-gradient(135deg, #ffffff, var(--accent-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-text p {
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .hero-img-container {
            position: relative;
            flex: 1;
            display: flex;
            justify-content: center;
        }

        /* Lab Reticle Frame Effect */
        .hero-img-box {
            position: relative;
            border: 1px solid var(--border-lab);
            padding: 15px;
            background: rgba(17, 24, 39, 0.5);
        }

        .hero-img-box::before, .hero-img-box::after {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            border: 2px solid var(--accent-cyan);
        }

        .hero-img-box::before { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
        .hero-img-box::after { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

        .hero-img-box img {
            width: 320px;
            height: 400px;
            object-fit: cover;
            display: block;
        }

        /* Core Sections */
        section {
            padding: 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2rem;
            margin-bottom: 3rem;
            position: relative;
            display: inline-block;
            letter-spacing: 1px;
        }

        .section-title::after {
            content: " [SYS_DATA_VAL]";
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.8rem;
            color: var(--accent-cyan);
            vertical-align: middle;
        }

        /* Research Card Showcase */
        .research-panel {
            background: var(--bg-secondary);
            border: 1px solid var(--border-lab);
            border-top: 4px solid var(--accent-cyan);
            padding: 2.5rem;
            border-radius: 4px;
        }

        .research-badge {
            background: rgba(59, 130, 246, 0.15);
            color: #60a5fa;
            padding: 0.3rem 0.7rem;
            font-size: 0.8rem;
            border-radius: 99px;
            margin-bottom: 1rem;
            display: inline-block;
        }

        .research-panel h3 {
            font-size: 1.6rem;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .research-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            margin-top: 1.5rem;
        }

        .research-list {
            list-style: none;
        }

        .research-list li {
            margin-bottom: 0.8rem;
            padding-left: 1.5rem;
            position: relative;
            color: var(--text-muted);
        }

        .research-list li::before {
            content: "✓";
            position: absolute;
            left: 0;
            color: var(--accent-cyan);
        }

        /* Cards Grid for Lab Data */
        .lab-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .lab-card {
            background: var(--bg-secondary);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 4px;
            transition: 0.3s;
        }

        .lab-card:hover {
            border-color: var(--accent-cyan);
            transform: translateY(-3px);
            background: rgba(17, 24, 39, 0.8);
        }

        .lab-card i {
            font-size: 1.8rem;
            color: var(--accent-cyan);
            margin-bottom: 1rem;
        }

        .lab-card h4 {
            font-size: 1.2rem;
            margin-bottom: 0.8rem;
        }

        .lab-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        /* Skills Tags */
        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
        }

        .skill-tag {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.6rem 1.2rem;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.9rem;
            transition: 0.2s;
        }

        .skill-tag:hover {
            background: rgba(6, 182, 212, 0.08);
            border-color: var(--accent-cyan);
            color: var(--accent-cyan);
        }

        /* Buttons & Footer */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-cyan));
            color: white;
            text-decoration: none;
            padding: 0.8rem 1.8rem;
            font-weight: 600;
            border-radius: 4px;
            transition: 0.3s;
            border: none;
            cursor: pointer;
        }

        .btn:hover {
            box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
            opacity: 0.95;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--accent-cyan);
            color: var(--accent-cyan);
            margin-left: 1rem;
        }

        .btn-outline:hover {
            background: rgba(6, 182, 212, 0.1);
        }

        footer {
            background: #060b13;
            padding: 3rem 2rem;
            text-align: center;
            border-top: 1px solid var(--border-lab);
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .footer-socials {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }

        .footer-socials a {
            color: var(--text-main);
            font-size: 1.5rem;
            transition: 0.3s;
        }

        .footer-socials a:hover {
            color: var(--accent-cyan);
        }

        /* Responsive */
        @media (max-width: 968px) {
            header {
                flex-direction: column-reverse;
                text-align: center;
                padding-top: 6rem;
            }
            .nav-links { display: none; }
            .hero-text h1 { font-size: 2.5rem; }
            .research-grid { grid-template-columns: 1fr; }
            .hero-img-box img { width: 260px; height: 340px; }
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav>
        <div class="nav-logo">PANDU_DIAN // LAB_PORTFOLIO</div>
        <ul class="nav-links">
            <li><a href="#about">Tentang</a></li>
            <li><a href="#research">Riset Utama</a></li>
            <li><a href="#lab-experience">Eksperimen</a></li>
            <li><a href="#skills">Kompetensi</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <header id="about">
        <div class="hero-text">
            <span class="hero-tag">STATUS: CHEMICAL ENGINEERING STUDENT</span>
            <h1>Pandu Dian</h1>
            <p>Mahasiswa Program Studi Teknologi Kimia Industri Terapan di Politeknik Negeri Ujung Pandang. Berfokus pada analisis laboratorium komprehensif, optimasi rekayasa proses, serta validasi data terstruktur yang berorientasi pada prinsip keberlanjutan industri.</p>
            <div style="margin-top: 1rem;">
                <a href="https://www.linkedin.com/in/pandu-dian-938645384" target="_blank" class="btn"><i class="fab fa-linkedin"></i> LinkedIn Profile</a>
                <a href="mailto:pandudian022@gmail.com" class="btn btn-outline"><i class="fas fa-envelope"></i> Hubungi via Email</a>
            </div>
        </div>
        <div class="hero-img-container">
            <div class="hero-img-box">
                <!-- Memanggil foto terbaru Anda secara langsung melalui kode -->
                <img src="Foto profil Pandu_2.jpeg.jpg" alt="Pandu Dian - Jas Lab">
            </div>
        </div>
    </header>

    <!-- Research Focus Section -->
    <section id="research">
        <h2 class="section-title">Fokus Penelitian Utama</h2>
        <div class="research-panel">
            <span class="research-badge"><i class="fas fa-recycle"></i> Circular Economy & Waste Valorization</span>
            <h3>Pemurnian Serat Selulosa Asetat Daur Ulang (rCDA) dari Limbah Puntung Rokok dan Aplikasinya pada Campuran Aspal SMA</h3>
            <p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6;">
                Proyek inovatif ini mengeksplorasi ekstraksi serat selulosa asetat berkualitas tinggi dari limbah puntung rokok yang terabaikan untuk diaplikasikan sebagai bahan aditif penguat struktur perkerasan jalan tipe Stone Matrix Asphalt (SMA).
            </p>
            <hr style="border: 0; border-top: 1px solid rgba(255,255,255,0.05); margin: 1.5rem 0;">
            <div class="research-grid">
                <div>
                    <h4 style="margin-bottom: 0.8rem; color: var(--accent-cyan);">Cakupan Modul Kerja:</h4>
                    <ul class="research-list">
                        <li>Preparasi, pencucian bahan baku, dan destruksi kontaminan kimia pengotor.</li>
                        <li>Perlakuan kimia (Chemical treatment) fraksinasi menggunakan larutan alkali NaOH.</li>
                        <li>Penerapan sistem manajemen mutu laboratorium berbasis standar ISO/IEC 17025.</li>
                        <li>Sistem pendokumentasian logbook penelitian teratur demi ketertelusuran data uji.</li>
                    </ul>
                </div>
                <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 4px; border: 1px dashed rgba(22, 211, 238, 0.2);">
                    <h5 style="color: white; margin-bottom: 0.5rem; font-family: monospace;">ANALYSIS METHOD</h5>
                    <p style="font-size: 0.85rem; color: var(--text-muted);">Integritas proses ditekankan pada validasi pengujian metode, kalibrasi instrumen, dan penelusuran galat analisis untuk menghasilkan data penelitian yang sahih.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Lab Experience & Experiments Section -->
    <section id="lab-experience">
        <h2 class="section-title">Rekam Jejak Laboratorium & Eksperimen</h2>
        <div class="lab-grid">
            <div class="lab-card">
                <i class="fas fa-flask"></i>
                <h4>Kimia Organik & Sintesis</h4>
                <p>Pengalaman langsung mencakup ekstraksi cair-cair, analisis kadar protein, hidrolisis metil salisilat, sintesis asam salisilat, serta isolasi senyawa polifenol aktif dari sampel biomassa.</p>
            </div>
            <div class="lab-card">
                <i class="fas fa-vial"></i>
                <h4>Kimia Fisika & Larutan</h4>
                <p>Eksperimen komprehensif penentuan diagram terner sistem tiga komponen, penentuan hukum Hess, pengukuran tegangan permukaan cairan, serta preparasi & standarisasi akurat larutan asam-basa.</p>
            </div>
            <div class="lab-card">
                <i class="fas fa-chart-line"></i>
                <h4>Kinetika Reaksi & Adsorpsi</h4>
                <p>Studi pengaruh katalis terhadap laju reaksi, penentuan energi aktivasi, serta pengolahan data isoterm adsorpsi (Langmuir dan Freundlich) menggunakan visualisasi matematis terstruktur.</p>
            </div>
            <div class="lab-card">
                <i class="fas fa-calculator"></i>
                <h4>Pengolahan & Pemodelan Data</h4>
                <p>Komputasi teknik kimia menggunakan Microsoft Excel untuk perhitungan neraca massa komponen, evaluasi galat eksperimental, serta pemodelan statistik regresi linear data laboratorium.</p>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
        <h2 class="section-title">Matriks Kompetensi Teknis</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
            <div>
                <h4 style="color: var(--accent-cyan); margin-bottom: 1rem;"><i class="fas fa-microscope"></i> Sistem Mutu Lab</h4>
                <div class="skills-container">
                    <span class="skill-tag">ISO/IEC 17025</span>
                    <span class="skill-tag">Good Laboratory Practice</span>
                    <span class="skill-tag">Metode Logbook Valid</span>
                    <span class="skill-tag">Ketertelusuran Data</span>
                </div>
            </div>
            <div>
                <h4 style="color: var(--accent-cyan); margin-bottom: 1rem;"><i class="fas fa-cogs"></i> Operasi Teknik</h4>
                <div class="skills-container">
                    <span class="skill-tag">Neraca Massa & Energi</span>
                    <span class="skill-tag">Destilasi Sederhana</span>
                    <span class="skill-tag">Teknologi Material</span>
                    <span class="skill-tag">Pengolahan Limbah</span>
                </div>
            </div>
            <div>
                <h4 style="color: var(--accent-cyan); margin-bottom: 1rem;"><i class="fas fa-code-branch"></i> Analisis Data</h4>
                <div class="skills-container">
                    <span class="skill-tag">Microsoft Excel</span>
                    <span class="skill-tag">Regresi Linear Statistik</span>
                    <span class="skill-tag">Analisis Galat</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-socials">
            <a href="https://www.linkedin.com/in/pandu-dian-938645384" target="_blank"><i class="fab fa-linkedin"></i></a>
            <a href="mailto:pandudian022@gmail.com"><i class="fas fa-envelope"></i></a>
        </div>
        <p>&copy; 2026 Pandu Dian. All Rights Reserved.</p>
        <p style="font-size: 0.75rem; margin-top: 0.5rem; color: var(--accent-cyan); font-family: monospace;">SYSTEM_STATUS: ONLINE // SECURE_ACCESS</p>
    </footer>

</body>
</html>
